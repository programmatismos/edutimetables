    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "@template/web": "workspace:*",
    "electron-updater": "^6.8.3"
  }
}
